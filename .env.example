# --- Required ---
# Secret token for Dashboard access (generate with: openssl rand -hex 32)
AUTH_TOKEN=your_secret_token_here

# --- Optional (Notifications) ---
# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=
# Your Telegram Chat ID from @userinfobot
TELEGRAM_CHAT_ID=

# --- Advanced ---
# Database connection string
DATABASE_URL=sqlite:mini-ops.db
# Display name for this server in the dashboard (defaults to hostname)
SERVER_NAME=
# Language for alerts and logging (en|ru)
AGENT_LANG=en
# Logging level (debug|info|warn|error)
RUST_LOG=info

# --- Cloud Push (optional — remove or set false to disable) ---
# See docs/CLOUD_PUSH.md for a full explanation of what is sent and why.
CLOUD_PUSH_ENABLED=false
CLOUD_HUB_URL=https://cloud.mini-ops.dev
CLOUD_AGENT_ID=ag_your_agent_id_here
CLOUD_AGENT_TOKEN=your_agent_token_here
CLOUD_PUSH_INTERVAL=60
# Allow plain HTTP for local testing ONLY. Never set true in production.
# CLOUD_PUSH_ALLOW_HTTP=false
